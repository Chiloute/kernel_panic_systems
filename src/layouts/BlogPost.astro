---
import Layout from "./Layout.astro";

interface Props {
  title: string;
  description?: string;
  date: Date;
  tags?: string[];
  backHref?: string;
  backLabel?: string;
  /** Classe Tailwind pour la couleur d'accent de la section */
  accentClass?: string;
  /** Badges supplémentaires affichés sous le titre (ex: CTF, difficulté) */
  badges?: { label: string; class: string }[];
}

const {
  title,
  description,
  date,
  tags = [],
  backHref = "/",
  backLabel = "Retour",
  accentClass = "text-blue-400",
  badges = [],
} = Astro.props;

function formatDate(d: Date) {
  return d.toLocaleDateString("fr-FR", {
    day: "numeric",
    month: "long",
    year: "numeric",
  });
}
---

<Layout title={title} description={description}>
  <article class="max-w-4xl mx-auto px-4 py-16">
    <!-- Retour -->
    <a
      href={backHref}
      class="inline-flex items-center gap-2 text-sm font-mono text-zinc-500 hover:text-zinc-200 mb-12 transition-colors group"
    >
      <svg
        class="w-4 h-4 transition-transform group-hover:-translate-x-0.5"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"
        ></path>
      </svg>
      {backLabel}
    </a>

    <!-- En-tête -->
    <header class="mb-12">
      <!-- Badges (writeup: difficulté, catégorie…) -->
      {
        badges.length > 0 && (
          <div class="flex flex-wrap gap-2 mb-4">
            {badges.map((b) => (
              <span
                class={`text-xs px-2.5 py-1 rounded font-mono border ${b.class}`}
              >
                {b.label}
              </span>
            ))}
          </div>
        )
      }

      <h1
        class="text-4xl md:text-5xl font-black tracking-tight text-zinc-100 mb-4 leading-tight"
      >
        {title}
      </h1>

      {
        description && (
          <p class="text-lg text-zinc-400 leading-relaxed mb-6">
            {description}
          </p>
        )
      }

      <div class="flex flex-wrap items-center gap-3">
        <time class={`font-mono text-sm ${accentClass}`}
          >{formatDate(date)}</time
        >
        {
          tags.length > 0 && (
            <>
              <span class="text-zinc-700">·</span>
              <div class="flex flex-wrap gap-2">
                {tags.map((tag) => (
                  <span class="text-xs px-2 py-0.5 bg-zinc-800 text-zinc-400 rounded font-mono border border-zinc-700">
                    {tag}
                  </span>
                ))}
              </div>
            </>
          )
        }
      </div>
    </header>

    <!-- Séparateur gradient -->
    <div
      class="h-px bg-gradient-to-r from-transparent via-zinc-700 to-transparent mb-12"
    >
    </div>

    <!-- Contenu Markdown -->
    <div class="prose-kps">
      <slot />
    </div>

    <!-- Pied d'article -->
    <div class="mt-16 pt-8 border-t border-zinc-800">
      <a
        href={backHref}
        class="inline-flex items-center gap-2 text-sm font-mono text-zinc-500 hover:text-zinc-200 transition-colors group"
      >
        <svg
          class="w-4 h-4 transition-transform group-hover:-translate-x-0.5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M15 19l-7-7 7-7"></path>
        </svg>
        {backLabel}
      </a>
    </div>
  </article>
</Layout>
