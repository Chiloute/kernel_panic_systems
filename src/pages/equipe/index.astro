---
import Layout from "../../layouts/Layout.astro";
import MemberCard from "../../components/MemberCard.svelte";
import MembresGrid from "../../components/MembresGrid.svelte";
import { bureau, membres, poleConfig } from "../../data/membres";
import type { Pole } from "../../data/membres";

const tousLesMembres = [
  ...bureau
    .filter((b) => b.poles?.length)
    .map((b) => ({
      pseudo: b.pseudo,
      avatar: b.avatar,
      poles: b.poles as Pole[],
    })),
  ...membres,
];

const [president, vp, ...bottom] = bureau;
---

<Layout
  title="Bureau"
  description="Organigramme et membres de Kernel Panic Systems"
>
  <main class="max-w-6xl mx-auto px-4 py-16">
    <!-- En-tête -->
    <div class="mb-16">
      <p class="font-mono text-zinc-500 text-sm mb-4">
        $ cat equipe/organigramme.txt
      </p>
      <h1 class="text-4xl md:text-5xl font-black tracking-tight mb-4">
        <span
          class="bg-gradient-to-r from-red-400 to-blue-400 bg-clip-text text-transparent"
          >~/</span
        >team
      </h1>
      <p class="text-zinc-500 max-w-xl leading-relaxed">
        Le bureau de l'association et ses membres, organisés par pôles
        d'activité.
      </p>
    </div>

    <!-- ══ Organigramme ══ -->
    <section class="mb-20">
      <p
        class="font-mono text-zinc-600 text-xs uppercase tracking-widest mb-10"
      >
        — Bureau général
      </p>

      <!-- Niveau 1 : Président -->
      <div class="flex justify-center mb-0">
        <div class="w-full max-w-xs">
          <MemberCard
            pseudo={president.pseudo}
            avatar={president.avatar}
            role={president.role}
            poles={president.poles}
            variant="bureau"
            client:load
          />
        </div>
      </div>

      <!-- Connecteur -->
      <div class="flex justify-center">
        <div class="w-px h-8 bg-gradient-to-b from-red-500/40 to-purple-500/40">
        </div>
      </div>

      <!-- Niveau 2 : Vice-Président -->
      <div class="flex justify-center mb-0">
        <div class="w-full max-w-xs">
          <MemberCard
            pseudo={vp.pseudo}
            avatar={vp.avatar}
            role={vp.role}
            poles={vp.poles}
            variant="bureau"
            client:load
          />
        </div>
      </div>

      <!-- Connecteur avec branches vers 3 -->
      <div class="flex justify-center">
        <div class="relative w-full max-w-2xl h-8">
          <div
            class="absolute left-1/2 -translate-x-1/2 top-0 w-px h-4 bg-purple-500/40"
          >
          </div>
          <div
            class="absolute left-[16.67%] right-[16.67%] top-4 h-px bg-gradient-to-r from-red-500/30 via-purple-500/30 to-blue-500/30"
          >
          </div>
          <div class="absolute left-[16.67%] top-4 w-px h-4 bg-red-500/30">
          </div>
          <div
            class="absolute left-1/2 -translate-x-1/2 top-4 w-px h-4 bg-purple-500/30"
          >
          </div>
          <div class="absolute right-[16.67%] top-4 w-px h-4 bg-blue-500/30">
          </div>
        </div>
      </div>

      <!-- Niveau 3 -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 max-w-2xl mx-auto">
        {
          bottom.map((member) => (
            <MemberCard
              pseudo={member.pseudo}
              avatar={member.avatar}
              role={member.role}
              poles={member.poles}
              variant="bureau"
              client:load
            />
          ))
        }
      </div>
    </section>

    <!-- Séparateur gradient -->
    <div
      class="h-px bg-gradient-to-r from-transparent via-zinc-700 to-transparent mb-20"
    >
    </div>

    <!-- ══ Membres par pôle ══ -->
    <section>
      <p class="font-mono text-zinc-600 text-xs uppercase tracking-widest mb-4">
        — Membres &amp; pôles
      </p>

      <!-- Légende -->
      <div class="flex flex-wrap gap-4 mb-10">
        {
          Object.entries(poleConfig).map(([, cfg]) => (
            <div class="flex items-center gap-2">
              <span class={`w-2 h-2 rounded-full ${cfg.dot}`} />
              <span class="text-xs font-mono text-zinc-400">{cfg.label}</span>
            </div>
          ))
        }
      </div>

      <MembresGrid membres={tousLesMembres} client:load />
    </section>
  </main>
</Layout>
