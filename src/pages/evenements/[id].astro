---
import { getCollection, render } from "astro:content";
import BlogPost from "../../layouts/BlogPost.astro";

export async function getStaticPaths() {
  const events = await getCollection("evenements", ({ data }) => !data.draft);
  return events.map((event) => ({
    params: { id: event.id },
    props: { event },
  }));
}

type Props = {
  event: Awaited<ReturnType<typeof getCollection<"evenements">>>[number];
};

const { event } = Astro.props;
const { Content } = await render(event);

const now = new Date();
now.setHours(0, 0, 0, 0);
const isPast = event.data.date < now;

const badges = [
  {
    label: isPast ? "Passé" : "À venir",
    class: isPast
      ? "text-zinc-500 bg-zinc-800 border-zinc-700"
      : "text-blue-400 bg-blue-500/10 border-blue-500/20",
  },
  ...(event.data.lieu
    ? [
        {
          label: `📍 ${event.data.lieu}`,
          class: "text-zinc-400 bg-zinc-800 border-zinc-700",
        },
      ]
    : []),
];
---

<BlogPost
  title={event.data.titre}
  description={event.data.description}
  date={event.data.date}
  tags={[]}
  backHref="/evenements"
  backLabel="Événements"
  accentClass="text-zinc-400"
  badges={badges}
>
  <Content />
</BlogPost>
