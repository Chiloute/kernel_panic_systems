---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

const allProjets = await getCollection("projets", ({ data }) => !data.draft);
const latestProjets = allProjets
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const allEvents = await getCollection("evenements", ({ data }) => !data.draft);
const latestEvents = allEvents
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const allWriteups = await getCollection("writeups", ({ data }) => !data.draft);
const latestWriteups = allWriteups
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const now = new Date();

function formatDate(date: Date) {
  return date.toLocaleDateString("fr-FR", {
    day: "numeric",
    month: "long",
    year: "numeric",
  });
}

const diffColors: Record<string, string> = {
  easy: "text-green-400  bg-green-400/10  border-green-400/20",
  medium: "text-yellow-400 bg-yellow-400/10 border-yellow-400/20",
  hard: "text-orange-400 bg-orange-400/10 border-orange-400/20",
  insane: "text-red-400    bg-red-400/10    border-red-400/20",
};
---

<Layout
  title="Kernel Panic Systems"
  description="Association d'informatique et de cybersécurité — CTF, projets, conférences."
>
  <!-- ═══════════════════════ HERO ═══════════════════════ -->
  <section class="relative overflow-hidden">
    <!-- Glow red (gauche) + blue (droite) -->
    <div
      class="absolute top-1/3 left-0 w-[600px] h-[600px] bg-red-600/8 rounded-full blur-[120px] -translate-x-1/2 pointer-events-none"
    >
    </div>
    <div
      class="absolute top-1/3 right-0 w-[600px] h-[600px] bg-blue-600/8 rounded-full blur-[120px] translate-x-1/2 pointer-events-none"
    >
    </div>

    <div class="relative max-w-6xl mx-auto px-4 py-28 md:py-44">
      <p class="font-mono text-zinc-500 text-sm mb-8">
        $ systemctl start kps.service
      </p>

      <h1
        class="text-6xl md:text-8xl font-black tracking-tight leading-none mb-8"
      >
        <span class="text-zinc-100">Kernel</span><br />
        <span
          class="bg-gradient-to-r from-red-500 to-blue-500 bg-clip-text text-transparent"
          >Panic</span
        ><br />
        <span class="text-zinc-100">Systems</span>
      </h1>

      <!-- Red Team / Blue Team divider -->
      <div class="flex items-center gap-4 mb-6 max-w-md">
        <span class="font-mono text-xs text-red-400 tracking-widest uppercase"
          >Red Team</span
        >
        <div
          class="flex-1 h-px bg-gradient-to-r from-red-500 via-purple-500 to-blue-500"
        >
        </div>
        <span class="font-mono text-xs text-blue-400 tracking-widest uppercase"
          >Blue Team</span
        >
      </div>

      <p class="text-zinc-400 max-w-xl mb-10 leading-relaxed">
        Passionnés d'informatique et de cybersécurité. On attaque, on défend, on
        partage. CTF, projets open-source, conférences — rejoins-nous pour
        apprendre à penser comme un attaquant et sécuriser comme un défenseur.
      </p>

      <div class="flex flex-wrap gap-4">
        <a
          href="/equipe"
          class="px-6 py-3 bg-red-600 hover:bg-red-500 text-white font-mono font-bold rounded transition-colors text-sm"
        >
          Rejoindre l'asso
        </a>
        <a
          href="/projets"
          class="px-6 py-3 border border-blue-700 text-blue-400 font-mono rounded hover:bg-blue-600/10 hover:border-blue-500 transition-colors text-sm"
        >
          Voir les projets →
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════ PROJETS ═══════════════════════ -->
  <section class="max-w-6xl mx-auto px-4 py-16">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-2xl font-bold font-mono">
        <span class="text-blue-400">~/</span>projets
      </h2>
      <a
        href="/projets"
        class="text-sm font-mono text-zinc-600 hover:text-blue-400 transition-colors"
      >
        voir tout →
      </a>
    </div>

    {
      latestProjets.length > 0 ? (
        <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
          {latestProjets.map((projet) => (
            <a
              href={`/projets/${projet.id}`}
              class="group block p-5 bg-zinc-900 border border-zinc-800 rounded-lg hover:border-blue-500/30 transition-all"
            >
              <h3 class="font-bold text-zinc-100 group-hover:text-blue-400 transition-colors mb-2 line-clamp-2">
                {projet.data.titre}
              </h3>
              <p class="text-sm text-zinc-500 mb-4 line-clamp-2 leading-relaxed">
                {projet.data.description}
              </p>
              <div class="flex items-center justify-between gap-2">
                <div class="flex flex-wrap gap-1">
                  {projet.data.tags.slice(0, 3).map((tag) => (
                    <span class="text-xs px-2 py-0.5 bg-zinc-800 text-zinc-400 rounded font-mono">
                      {tag}
                    </span>
                  ))}
                </div>
                <time class="text-xs text-zinc-600 font-mono shrink-0">
                  {projet.data.date.getFullYear()}
                </time>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <p class="text-zinc-700 font-mono text-sm">
          // Aucun projet pour le moment
        </p>
      )
    }
  </section>

  <div class="max-w-6xl mx-auto px-4">
    <div class="border-t border-zinc-800/60"></div>
  </div>

  <!-- ═══════════════════════ ÉVÉNEMENTS ═══════════════════════ -->
  <section class="max-w-6xl mx-auto px-4 py-16">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-2xl font-bold font-mono">
        <span class="text-zinc-400">~/</span>événements
      </h2>
      <a
        href="/evenements"
        class="text-sm font-mono text-zinc-600 hover:text-zinc-300 transition-colors"
      >
        voir tout →
      </a>
    </div>

    {
      latestEvents.length > 0 ? (
        <div class="flex flex-col gap-3">
          {latestEvents.map((event) => {
            const isPast = event.data.date < now;
            return (
              <a
                href={`/evenements/${event.id}`}
                class="group flex items-center gap-5 p-4 bg-zinc-900 border border-zinc-800 rounded-lg hover:border-zinc-600 transition-all"
              >
                <div class="shrink-0 text-center w-12">
                  <div class="text-xl font-bold font-mono leading-none text-zinc-100">
                    {String(event.data.date.getDate()).padStart(2, "0")}
                  </div>
                  <div class="text-xs text-zinc-500 font-mono uppercase tracking-widest mt-0.5">
                    {event.data.date.toLocaleDateString("fr-FR", {
                      month: "short",
                    })}
                  </div>
                </div>

                <div class="flex-1 min-w-0">
                  <h3 class="font-bold text-zinc-100 group-hover:text-zinc-50 transition-colors truncate">
                    {event.data.titre}
                  </h3>
                  {event.data.lieu && (
                    <p class="text-xs text-zinc-500 mt-0.5 font-mono">
                      {event.data.lieu}
                    </p>
                  )}
                </div>

                <span
                  class={`shrink-0 text-xs px-2.5 py-1 rounded font-mono border ${
                    isPast
                      ? "text-zinc-600 bg-zinc-800/50 border-zinc-700"
                      : "text-blue-400 bg-blue-500/10 border-blue-500/20"
                  }`}
                >
                  {isPast ? "passé" : "à venir"}
                </span>
              </a>
            );
          })}
        </div>
      ) : (
        <p class="text-zinc-700 font-mono text-sm">
          // Aucun événement pour le moment
        </p>
      )
    }
  </section>

  <div class="max-w-6xl mx-auto px-4">
    <div class="border-t border-zinc-800/60"></div>
  </div>

  <!-- ═══════════════════════ CTF BANNER ═══════════════════════ -->
  <section class="max-w-6xl mx-auto px-4 py-16">
    <!-- Gradient border via wrapper -->
    <div
      class="p-[1px] rounded-xl bg-gradient-to-r from-red-700 via-purple-700 to-blue-700"
    >
      <div class="relative overflow-hidden rounded-xl bg-zinc-950 p-8 md:p-12">
        <!-- Glows internes -->
        <div
          class="absolute -top-12 -left-12 w-48 h-48 bg-red-600/10 rounded-full blur-2xl pointer-events-none"
        >
        </div>
        <div
          class="absolute -bottom-12 -right-12 w-48 h-48 bg-blue-600/10 rounded-full blur-2xl pointer-events-none"
        >
        </div>

        <div class="relative">
          <div class="flex items-center gap-3 mb-4">
            <span
              class="font-mono text-xs text-red-400 tracking-widest uppercase px-2 py-1 border border-red-500/30 rounded bg-red-500/5"
            >
              Offensive
            </span>
            <div
              class="h-px flex-1 max-w-xs bg-gradient-to-r from-red-500/30 to-blue-500/30"
            >
            </div>
            <span
              class="font-mono text-xs text-blue-400 tracking-widest uppercase px-2 py-1 border border-blue-500/30 rounded bg-blue-500/5"
            >
              Defensive
            </span>
          </div>

          <h2 class="text-3xl md:text-4xl font-black mb-3">
            Capture{" "}
            <span
              class="bg-gradient-to-r from-red-400 to-blue-400 bg-clip-text text-transparent"
            >
              The Flag
            </span>
          </h2>

          <p class="text-zinc-400 max-w-xl mb-6 leading-relaxed">
            On participe régulièrement à des compétitions CTF en équipe. Web,
            reverse, crypto, pwn, forensics — comprendre comment ça casse pour
            mieux le sécuriser. Nos solutions sont publiées en writeups.
          </p>

          <div class="flex flex-wrap gap-3">
            <a
              href="/writeups"
              class="px-5 py-2.5 bg-red-600 hover:bg-red-500 text-white font-mono font-bold rounded transition-colors text-sm"
            >
              Voir tous les writeups
            </a>
            <a
              href="/evenements"
              class="px-5 py-2.5 border border-blue-700 text-blue-400 font-mono rounded hover:bg-blue-600/10 hover:border-blue-500 transition-colors text-sm"
            >
              Nos événements →
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════ WRITEUPS ═══════════════════════ -->
  <section class="max-w-6xl mx-auto px-4 pb-24">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-2xl font-bold font-mono">
        <span class="text-red-400">~/</span>writeups
      </h2>
      <a
        href="/writeups"
        class="text-sm font-mono text-zinc-600 hover:text-red-400 transition-colors"
      >
        voir tout →
      </a>
    </div>

    {
      latestWriteups.length > 0 ? (
        <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
          {latestWriteups.map((writeup) => (
            <a
              href={`/writeups/${writeup.id}`}
              class="group block p-5 bg-zinc-900 border border-zinc-800 rounded-lg hover:border-red-500/30 transition-all"
            >
              <div class="flex items-center gap-2 mb-3">
                <span
                  class={`text-xs px-2 py-0.5 rounded font-mono border ${diffColors[writeup.data.difficulte]}`}
                >
                  {writeup.data.difficulte}
                </span>
                <span class="text-xs text-zinc-500 font-mono">
                  {writeup.data.categorie}
                </span>
                {writeup.data.points && (
                  <span class="text-xs text-zinc-600 font-mono ml-auto">
                    {writeup.data.points} pts
                  </span>
                )}
              </div>
              <h3 class="font-bold text-zinc-100 group-hover:text-red-400 transition-colors mb-1 line-clamp-2">
                {writeup.data.titre}
              </h3>
              <p class="text-xs text-zinc-500 font-mono mb-3">
                {writeup.data.ctf}
              </p>
              <div class="flex flex-wrap gap-1">
                {writeup.data.tags.slice(0, 3).map((tag) => (
                  <span class="text-xs px-2 py-0.5 bg-zinc-800 text-zinc-400 rounded font-mono">
                    {tag}
                  </span>
                ))}
              </div>
            </a>
          ))}
        </div>
      ) : (
        <p class="text-zinc-700 font-mono text-sm">
          // Aucun writeup pour le moment
        </p>
      )
    }
  </section>
</Layout>
