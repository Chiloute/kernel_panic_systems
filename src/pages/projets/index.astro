---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const projets = await getCollection("projets", ({ data }) => !data.draft);
const sorted = projets.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
---

<Layout
  title="Projets"
  description="Les projets techniques et sécurité de Kernel Panic Systems."
>
  <main class="max-w-6xl mx-auto px-4 py-16">
    <div class="mb-12">
      <p class="font-mono text-zinc-500 text-sm mb-4">$ ls -la ~/projets/</p>
      <h1 class="text-4xl md:text-5xl font-black tracking-tight mb-4">
        <span class="text-blue-400">~/</span>projets
      </h1>
      <p class="text-zinc-500 max-w-xl leading-relaxed">
        Nos projets open-source, outils de sécurité et expérimentations
        techniques.
      </p>
      <p class="font-mono text-xs text-zinc-600 mt-3">
        {sorted.length} projet{sorted.length > 1 ? "s" : ""}
      </p>
    </div>

    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {
        sorted.map((projet) => (
          <a
            href={`/projets/${projet.id}`}
            class="group block p-5 bg-zinc-900 border border-zinc-800 rounded-lg hover:border-blue-500/30 transition-all"
          >
            <h2 class="font-bold text-zinc-100 group-hover:text-blue-400 transition-colors mb-2 line-clamp-2">
              {projet.data.titre}
            </h2>
            <p class="text-sm text-zinc-500 mb-4 line-clamp-3 leading-relaxed">
              {projet.data.description}
            </p>
            <div class="flex items-center justify-between gap-2">
              <div class="flex flex-wrap gap-1">
                {projet.data.tags.slice(0, 3).map((tag) => (
                  <span class="text-xs px-2 py-0.5 bg-zinc-800 text-zinc-400 rounded font-mono">
                    {tag}
                  </span>
                ))}
                {projet.data.tags.length > 3 && (
                  <span class="text-xs text-zinc-600 font-mono self-center">
                    +{projet.data.tags.length - 3}
                  </span>
                )}
              </div>
              <time class="text-xs text-zinc-600 font-mono shrink-0">
                {projet.data.date.getFullYear()}
              </time>
            </div>
          </a>
        ))
      }
    </div>

    {
      sorted.length === 0 && (
        <p class="text-zinc-700 font-mono text-sm">
          // Aucun projet pour le moment
        </p>
      )
    }
  </main>
</Layout>
