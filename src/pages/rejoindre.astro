---

<Layout
  title="Rejoindre KPS — Kernel Panic Systems"
  description="Adhère à l'association, rejoins notre Discord, suis-nous sur Instagram."
>
  <!-- Glow background -->
  <div class="relative overflow-hidden">
    <div
      class="absolute top-0 left-0 w-[500px] h-[500px] bg-red-600/8 rounded-full blur-[120px] -translate-x-1/2 pointer-events-none"
    ></div>
    <div
      class="absolute top-0 right-0 w-[500px] h-[500px] bg-blue-600/8 rounded-full blur-[120px] translate-x-1/2 pointer-events-none"
    ></div>

    <div class="relative max-w-lg mx-auto px-4 py-24 md:py-32">
      <!-- Header -->
      <p class="font-mono text-zinc-500 text-sm mb-6">$ kps --join</p>

      <h1 class="text-4xl md:text-5xl font-black tracking-tight mb-4">
        <span class="text-zinc-100">Rejoindre</span><br />
        <span
          class="bg-gradient-to-r from-red-500 to-blue-500 bg-clip-text text-transparent"
          >KPS</span
        >
      </h1>

      <p class="text-zinc-400 mb-10 leading-relaxed">
        Plusieurs façons de nous rejoindre ou de rester en contact.
      </p>

      <!-- Divider -->
      <div
        class="h-px bg-gradient-to-r from-transparent via-zinc-700 to-transparent mb-10"
      ></div>

      <!-- Links -->
      <div class="flex flex-col gap-3">
        {
          links.map((link) => (
            <a
              href={link.href}
              target={link.external ? "_blank" : undefined}
              rel={link.external ? "noopener noreferrer" : undefined}
              class={`group flex items-center gap-4 bg-zinc-900 border border-zinc-800 rounded-lg px-6 py-4 transition-colors ${
                link.accent === "red"
                  ? "hover:border-red-500/50"
                  : "hover:border-blue-500/50"
              }`}
            >
              <span
                class={`shrink-0 ${link.accent === "red" ? "text-red-400" : "text-blue-400"}`}
              >
                <Fragment set:html={link.icon} />
              </span>
              <span class="flex-1 min-w-0">
                <span class="block font-mono font-bold text-zinc-100 text-sm">
                  {link.label}
                </span>
                <span class="block text-xs text-zinc-500 mt-0.5">
                  {link.description}
                </span>
              </span>
              <span class="text-zinc-600 group-hover:text-zinc-400 transition-colors font-mono text-sm">
                →
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </div>
</Layout>
