---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const allArticles = await getCollection("articles", ({ data }) => !data.draft);
const sorted = allArticles.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const categorieConfig: Record<string, { label: string; class: string }> = {
  avis:     { label: "Avis",     class: "text-purple-400 bg-purple-500/10 border-purple-500/20" },
  tutoriel: { label: "Tutoriel", class: "text-blue-400 bg-blue-500/10 border-blue-500/20" },
  retour:   { label: "Retour d'expérience", class: "text-amber-400 bg-amber-500/10 border-amber-500/20" },
};

function fmtDate(date: Date) {
  return date.toLocaleDateString("fr-FR", {
    day: "numeric",
    month: "long",
    year: "numeric",
  });
}
---

<Layout
  title="Articles"
  description="Avis sur des technos, tutoriels et retours d'expérience de Kernel Panic Systems."
>
  <main class="max-w-6xl mx-auto px-4 py-16">
    <div class="mb-12">
      <p class="font-mono text-zinc-500 text-sm mb-4">
        $ cat articles/index.md
      </p>
      <h1 class="text-4xl md:text-5xl font-black tracking-tight mb-4">
        <span class="text-purple-400">~/</span>articles
      </h1>
      <p class="text-zinc-500 max-w-xl leading-relaxed">
        Nos avis sur des technos, tutoriels techniques et retours d'expérience
        — ce qu'on a appris, ce qu'on recommande, ce qu'on éviterait.
      </p>
    </div>

    {
      sorted.length > 0 ? (
        <div class="flex flex-col gap-4">
          {sorted.map((article) => {
            const cat = categorieConfig[article.data.categorie];
            return (
              <a
                href={`/articles/${article.id}`}
                class="group p-5 bg-zinc-900 border border-zinc-800 rounded-lg hover:border-purple-500/30 transition-all"
              >
                <div class="flex items-start gap-4">
                  <div class="flex-1 min-w-0">
                    <div class="flex flex-wrap items-center gap-2 mb-2">
                      <span
                        class={`text-xs px-2.5 py-0.5 rounded font-mono border ${cat.class}`}
                      >
                        {cat.label}
                      </span>
                      <time class="text-xs font-mono text-zinc-600">
                        {fmtDate(article.data.date)}
                      </time>
                    </div>
                    <h2 class="font-bold text-zinc-100 group-hover:text-purple-400 transition-colors mb-1">
                      {article.data.titre}
                    </h2>
                    <p class="text-sm text-zinc-500 line-clamp-2">
                      {article.data.description}
                    </p>
                    {article.data.tags.length > 0 && (
                      <div class="flex flex-wrap gap-1.5 mt-3">
                        {article.data.tags.map((tag) => (
                          <span class="text-xs px-2 py-0.5 bg-zinc-800 text-zinc-500 rounded font-mono border border-zinc-700">
                            {tag}
                          </span>
                        ))}
                      </div>
                    )}
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      ) : (
        <div class="text-center py-24">
          <p class="font-mono text-zinc-600 text-sm">Aucun article pour l'instant.</p>
        </div>
      )
    }
  </main>
</Layout>
